---
export const prerender = false
import Layout from '@layouts/Base.astro';

import Banner from '@components/Banner';
import Homepage from "@modules/Homepage"
import { fetchHomepage } from '@data/fetchers';
import type { HomepageData } from '@data/types';
import { fetchSettings, type SettingsData } from '../data/settings'; 
import Meta from '../components/Meta/Meta.astro';

const draftMode = Astro.locals.draftMode ?? false
const home: HomepageData = await fetchHomepage(draftMode);
const settings: SettingsData = await fetchSettings(draftMode);
---

<Layout>
    <Meta title="Home" settings={settings} />
  <!-- <Banner title="Register to access the event recordings" ctaText="Register Now" ctaLink="https://seqera.swoogo.com/nextflow-summit-boston-2025" client:load />  -->
   <Homepage data={home}  client:load/>
</Layout>
