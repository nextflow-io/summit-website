---
import Layout from "@layouts/Base.astro";
import Meta from '@components/Meta/Meta.astro';
import {getAllVirtualSpeakers} from "@data/speakers";
import { fetchSettings, type SettingsData } from '@data/settings'; 
const sortedMembers = getAllVirtualSpeakers[0].speakers.sort((a, b) =>
  a.name.localeCompare(b.name)
);
const settings: SettingsData = await fetchSettings();
---

<Layout namespace="2026/virtual">
  <Meta title="Speakers" sanityImage="default" settings={settings}/>

  <section class="py-20 bg-black text-white">
    <div class="container-lg">
      <h1 class="h3 mb-4">Speakers</h1>
      <p>Check back soon for a list of this year's speakers and presenters.</p>
    </div>
  </section>

  <!-- <div class="container mt-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-10">
      {
        sortedMembers.map((name, index) => (
           <div>
           <SpeakersSection 
           person={name} 
           index={index}
           location="virtual"
           client:only="react"/>
           </div>
        ))
      }

    </div>
  </div> -->

</Layout>
