---
import Layout from "@layouts/Base.astro";
import Meta from '@components/Meta/Meta.astro';
import StandardPage from "@modules/StandardPage"
import { fetchBostonRegister} from '@data/fetchers';
import type { PageData } from '@data/types';

const register: PageData = await fetchBostonRegister();
---

<Layout showNav={false} redirect="/2026/boston/register/form">
    <Meta title="Register" />
    <StandardPage data={register}  client:load/>
</Layout>
