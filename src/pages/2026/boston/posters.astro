---
export const prerender = false
import Layout from '@layouts/Base.astro';
import Meta from '@components/Meta/Meta.astro';
import SpeakersSection from '@modules/SpeakersSection';
import { getAllPosters } from '@data/posters';
import { fetchSettings, type SettingsData } from '@data/settings';

const draftMode = Astro.locals.draftMode ?? false
const postersData = await getAllPosters(draftMode)
const sortedMembers = postersData[0]?.posters?.sort((a, b) =>
  a.name.localeCompare(b.name)
);
const settings: SettingsData = await fetchSettings(draftMode);
---

<Layout namespace="2026/boston">
  <Meta title="Posters" sanityImage="default"  settings={settings}/>

  <div class="">
    <section class="py-20 bg-black text-white">
      <div class="container-xl">
        <h1 class="h3 mb-4">Posters</h1>
      </div>
    </section>
  
  <section class="bg-white text-black py-10">
    <div class="container-xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
        {
          sortedMembers?.map((name, index) => (
            <div class="h-full min-h-0">
              <SpeakersSection
                person={name}
                index={index}
                location="boston"
                client:only="react"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>
  </div>
</Layout>
