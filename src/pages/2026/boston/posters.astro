---
import Layout from '@layouts/Base.astro';
import Meta from '@components/Meta/Meta.astro';
import PostersSection from '@modules/PostersSection';
import { getAllPosters } from '@data/posters';
import { fetchSettings, type SettingsData } from '@data/settings'; 
const sortedMembers = getAllPosters[0].posters.sort((a, b) =>
  a.name.localeCompare(b.name)
);

const settings: SettingsData = await fetchSettings();

---

<Layout namespace="2026/boston">
  <Meta title="Posters" sanityImage="default"  settings={settings}/>

  <div class="">
    <section class="py-20 bg-black text-white">
      <div class="container-lg">
        <h1 class="h3 mb-4">Posters</h1>
        <p>
          Check back soon to see this year's posters.
        </p>
      </div>
    </section>
    <!-- <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-10">
    {
      sortedMembers.map((name,index) => (
         <div>
         <PostersSection 
         person={name} 
         index="{index"
           location="boston"
         client:only="react"/>
         </div>
      ))
    }
  </div> -->
  </div>
</Layout>
