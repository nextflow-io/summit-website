---
export const prerender = false
import Layout from '@layouts/Base.astro';
import Meta from '@components/Meta/Meta.astro';
import { fetchSettings, type SettingsData } from '@data/settings';
import { fetchBcnAgenda } from '@data/agenda';
import { AllSchedules } from '@components/Schedule';

const settings: SettingsData = await fetchSettings(draftMode);
const agenda = await fetchBcnAgenda(draftMode);

const draftMode = Astro.locals.draftMode ?? false
const hasAgenda = agenda && agenda != null;
---

<Layout>
  <Meta title="Agenda" sanityImage="default" settings={settings} />
  <div class="bg-white text-black">
    <section class="py-20 bg-black text-white">
      <div class="container-xl">
        <h1 class="h3 mb-4">Agenda</h1>
           {hasAgenda ? (
        <p>Select the category to view the schedule.</p>
           ) : (
        <p class="">The agenda is coming soon. Check back later.</p>
           )}
      </div>
    </section>

    <section>
      {hasAgenda ? (
        <AllSchedules agenda={agenda} client:load location="barcelona"  />
      ) : (
       <></>
      )}
    </section>
  </div>
</Layout>